{
  "name": "speaksmart",
  "version": "1.0.0",
  "description": "SpeakSmart - Modern English Learning Platform for Students and Teachers",
  "main": "server/server.js",
  "scripts": {
    "setup": "node setup.js",
    "dev": "npm run setup && concurrently \"npm run server\" \"npm run client\"",
    "backend": "node backend.js",
    "server": "cd server && node server.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install && cd ../server && npm install"
  },
  "dependencies": {
    "@google/generative-ai": "^0.2.1",
    "bcryptjs": "^2.4.3",
    "concurrently": "^7.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "framer-motion": "^10.16.0",
    "helmet": "^6.0.1",
    "jsonwebtoken": "^9.0.0",
    "mysql2": "^3.22.1",
    "sqlite3": "^5.1.6"
  },
  "keywords": [
    "english",
    "learning",
    "education",
    "react",
    "nodejs"
  ],
  "author": "SpeakSmart Team",
  "license": "MIT"
}
