{
  "family": "speaksmart",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::<AWS_ACCOUNT_ID>:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::<AWS_ACCOUNT_ID>:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "speaksmart",
      "image": "<IMAGE_URI>",
      "portMappings": [
        {
          "containerPort": 5000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "5000" },
        { "name": "DB_PORT", "value": "3306" },
        { "name": "DB_NAME", "value": "english_learning_platform" },
        { "name": "CLIENT_URL", "value": "https://<your-alb-or-domain>" }
      ],
      "secrets": [
        { "name": "JWT_SECRET", "valueFrom": "/speaksmart/JWT_SECRET" },
        { "name": "DB_HOST", "valueFrom": "/speaksmart/DB_HOST" },
        { "name": "DB_USER", "valueFrom": "/speaksmart/DB_USER" },
        { "name": "DB_PASSWORD", "valueFrom": "/speaksmart/DB_PASSWORD" },
        { "name": "GOOGLE_GENERATIVE_AI_KEY", "valueFrom": "/speaksmart/GOOGLE_GENERATIVE_AI_KEY" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/speaksmart",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:5000/api/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
